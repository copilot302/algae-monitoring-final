# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/phycosense?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# ML Service Configuration
# Local: http://localhost:5001
# Deployed: https://your-ml-service-domain/ (no trailing slash)
ML_SERVICE_URL=http://localhost:5001

# If true, sensor data is rejected when ML service is unavailable.
# Keep false for production resilience.
ML_REQUIRED=false

# CORS (Optional - comma separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
